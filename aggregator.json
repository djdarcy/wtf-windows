{
    "_schema_version": 1,
    "name": "wtf-windows",
    "command": "wtf",
    "description": "wtf-windows -- Why is my Windows PC doing that? Many diagnostics, one command.",
    "tools_dir": "tools",
    "kits_dir": "kits",
    "manifest_name": ".wtf.json",
    "enabled_meta_commands": ["list", "info", "kit", "version"],
    "extra_reserved_commands": ["mode", "new", "add", "enhance", "graduate"],
    "schema": {
        "remote_url_paths": ["source.url"],
        "lifecycle_path": "lifecycle"
    },
    "discovery": {
        "tool_patterns": ["${tools_dir}/*/*"],
        "scan_hidden": false
    }
}
